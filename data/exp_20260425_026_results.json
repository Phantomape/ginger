{
  "rule": {
    "name": "passive_qqq_idle_cash_overlay",
    "definition": "Research-only overlay: estimate idle capital as 1 - active_position_count*20%, then apply a fraction of that idle capital to QQQ close-to-close returns when QQQ is >5% above its 200dma, QQQ 10d momentum exceeds the variant threshold, and QQQ 10d momentum exceeds SPY.",
    "parity_warning": "This does not yet model production fills, financing, or a real overlay ledger. Positive results require a follow-up implementation experiment."
  },
