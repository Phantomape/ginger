🧮 六、单窗口评分函数 Φ_w
def compute_phi_w(metrics):
    sharpe = clip(metrics["sharpe"], 0, 3)
    ret = clip(metrics["total_return_pct"], 0, 1)
    win = clip(metrics["win_rate"], 0.4, 0.8)
    pf = clip(metrics["profit_factor"], 1, 2.5)
    survival = clip(metrics["survival_rate"] / 0.1, 0, 1)
    trades = clip(metrics["total_trades"] / 30, 0, 1)

    drawdown = metrics["max_drawdown_pct"]

    # anti-hack: trade distribution penalty
    pnl = metrics["trade_pnls"]
    if len(pnl) > 1:
        pnl_std = std(pnl)
        pnl_mean = abs(mean(pnl)) + 1e-6
        instability = pnl_std / pnl_mean
    else:
        instability = 10.0

    # anti-hack: consistency penalty
    monthly = metrics["monthly_returns"]
    if len(monthly) > 0:
        losing_ratio = count(m < 0 for m in monthly) / len(monthly)
    else:
        losing_ratio = 1.0

    phi = (
        0.30 * sharpe +
        0.20 * ret +
        0.10 * win +
        0.10 * pf +
        0.10 * survival +
        0.10 * trades
        - 0.25 * drawdown
        - 0.10 * instability
        - 0.20 * losing_ratio
    )

    # hard penalties
    if metrics["total_trades"] < 15:
        phi -= 1.0

    if metrics["survival_rate"] < 0.03:
        phi -= 1.0

    return phi
🌍 七、全局 Φ 计算
def compute_global_phi(phi_ws, complexity_penalty):
    median_phi = median(phi_ws)
    std_phi = std(phi_ws)

    worst_phi = min(phi_ws)

    worst_penalty = max(0, 0.0 - worst_phi)

    return (
        median_phi
        - 0.20 * std_phi
        - 0.15 * worst_penalty
        - 0.10 * complexity_penalty
    )
